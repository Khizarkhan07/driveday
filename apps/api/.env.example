# Copy to .env and fill in. Never commit the real .env.

NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# Postgres connection string (Render/Railway/Supabase/Neon all provide one)
DATABASE_URL=postgresql://user:password@localhost:5432/motorcover_demo

# Random long string used to derive session cookie security — any random value is fine for a demo
SESSION_SECRET=change-me-to-a-random-string

# --- Vehicle lookup -----------------------------------------------------
# mock = fixture data, no signup required.
# oneautoapi = real DVLA-backed data via the One Auto API reseller (requires sign-up — see README).
# dvla = direct integration with DVLA's own Vehicle Enquiry Service (requires
# an API key from https://developer-portal.driver-vehicle-licensing.api.gov.uk).
VEHICLE_LOOKUP_PROVIDER=mock
ONEAUTOAPI_BASE_URL=
ONEAUTOAPI_KEY=

# DVLA Vehicle Enquiry Service — defaults to the production base URL; override
# with the UAT URL (https://uat.driver-vehicle-licensing.api.gov.uk/vehicle-enquiry)
# when testing with a UAT key.
DVLA_VES_BASE_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry
DVLA_VES_API_KEY=

# --- Stripe (TEST MODE ONLY — sk_test_/pk_test_ keys) --------------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# --- Resend (sandbox sender works without domain verification) -----------
RESEND_API_KEY=re_replace_me
EMAIL_FROM=MotorCover Demo <onboarding@resend.dev>

# --- Document storage -----------------------------------------------------
# local = disk under ./storage (fine for dev; ephemeral on most hosts)
# s3 = any S3-compatible store (e.g. Cloudflare R2) — requires @aws-sdk/client-s3
DOCUMENT_STORAGE=local
LOCAL_DOCS_DIR=storage
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
